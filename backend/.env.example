# Used when running the backend standalone (not via docker-compose).
# For the Docker workflow, use the root-level .env — these values are
# injected into the backend container by docker-compose.yml.

DATABASE_URL="postgresql://cvranker:cvranker@localhost:5433/cvranker?schema=public"
OPENAI_API_KEY="sk-..."
JWT_SECRET="change-me-to-a-long-random-string-at-least-32-chars"
JWT_EXPIRES_IN="7d"
PORT=3000
NODE_ENV=development
FRONTEND_URL="http://localhost:5173"
AI_MODEL_CHEAP="gpt-5-mini"
AI_MODEL_PREMIUM="gpt-5.1"
AI_CONCURRENCY_LIMIT=5
