# Copy this file to .env and fill in your values.
#
# For the Docker workflow (recommended), the only values you MUST set are
# OPENAI_API_KEY and JWT_SECRET. Everything else has a sensible default.

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# OpenAI API key
# Get one at https://platform.openai.com/api-keys
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
OPENAI_API_KEY="sk-..."

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# JWT — generate with: openssl rand -base64 64
# (PowerShell:  [Convert]::ToBase64String((1..48 | %{Get-Random -Max 256})) )
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
JWT_SECRET="change-me-to-a-long-random-string-at-least-32-chars"
JWT_EXPIRES_IN="7d"

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Database
# When running via docker-compose, Postgres is provided by the `postgres`
# service and DATABASE_URL is set for you inside the backend container.
#
# You only need to set DATABASE_URL here if you run the backend OUTSIDE
# Docker (e.g. `npm run start:dev` on the host). In that case, point it at
# a Postgres you control, for example:
#   DATABASE_URL="postgresql://cvranker:cvranker@localhost:5432/cvranker?schema=public"
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# DATABASE_URL="postgresql://cvranker:cvranker@localhost:5432/cvranker?schema=public"

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Environment
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
NODE_ENV=development
FRONTEND_URL=http://localhost:5173
VITE_API_URL=http://localhost:3000/api

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# AI configuration
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
AI_MODEL_CHEAP=gpt-5-mini
AI_MODEL_PREMIUM=gpt-5.1
AI_CONCURRENCY_LIMIT=5
